<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.SistemaVendas.Controller.PainelController"
            prefHeight="400.0" prefWidth="600.0">
    <VBox layoutX="260" layoutY="90" spacing="20">

        <Label text="Cadastro de Loja" style="-fx-font-size: 22; -fx-font-weight: bold;" />

        <HBox spacing="10">
            <TextField promptText="Nome da Loja"/>
            <TextField promptText="Telefone"/>
            <Button text="Cadastrar"/>
        </HBox>

        <TableView>
            <columns>
                <TableColumn text="ID"/>
                <TableColumn text="Nome"/>
                <TableColumn text="Telefone"/>
            </columns>
        </TableView>

    </VBox>

</AnchorPane>